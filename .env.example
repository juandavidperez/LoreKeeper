# Gemini API key (exposed in browser if no proxy is set — use VITE_API_PROXY_URL instead for production)
VITE_GEMINI_API_KEY=

# Optional: URL of a server-side proxy that forwards requests to Gemini API
# and injects the API key server-side (recommended for production)
VITE_API_PROXY_URL=

# Supabase — leave empty to run in local-only mode (no cloud sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

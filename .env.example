# --- Gemini AI ---
# Dev local (sin Vercel): pon la key aquí y ai.js llama a Google directamente
VITE_GEMINI_API_KEY=

# Producción / vercel dev: dejar VITE_GEMINI_API_KEY vacío.
# La serverless function api/gemini.js usa esta variable server-side (sin VITE_).
# Configurar en Vercel Dashboard → Settings → Environment Variables.
GEMINI_API_KEY=

# Supabase — leave empty to run in local-only mode (no cloud sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
